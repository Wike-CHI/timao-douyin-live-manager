# ============================================
# 前端生产环境配置模板
# 遵循：奥卡姆剃刀 + 希克定律
# ============================================
# 只需配置1个必需项：后端地址

# 🔗 后端服务地址（必需 - 只需配置1个）
# 如果前后端在同一服务器，使用容器名或 localhost
# 如果前后端分离，使用实际的后端服务器地址
BACKEND_URL=http://backend:11111

# 或者使用外部地址（前后端分离部署）
# BACKEND_URL=http://your-backend-server.com:11111

# 🌐 前端端口（可选，默认80）
FRONTEND_PORT=80

