# ============================================
# 前端开发环境变量
# ============================================

# ------------------------------------------
# 🌐 开发服务器配置
# ------------------------------------------
# Vite开发服务器端口
VITE_PORT=10013

# 开发服务器主机
VITE_HOST=127.0.0.1

# ------------------------------------------
# 🔗 后端服务地址
# ------------------------------------------
# FastAPI主服务地址
VITE_FASTAPI_URL=http://127.0.0.1:9030

# StreamCap服务地址（已集成到主服务）
VITE_STREAMCAP_URL=http://127.0.0.1:9030

# Douyin服务地址（已集成到主服务）
VITE_DOUYIN_URL=http://127.0.0.1:9030

# ------------------------------------------
# 🔐 认证配置
# ------------------------------------------
# 认证基础URL（可选，默认使用VITE_FASTAPI_URL）
# VITE_AUTH_BASE_URL=http://127.0.0.1:9030

# ------------------------------------------
# 🛠️ 开发配置
# ------------------------------------------
# 启用HMR热更新
VITE_HMR=true

# 启用源码映射
VITE_SOURCEMAP=true
