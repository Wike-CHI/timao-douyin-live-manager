{
  "name": "ast-voice-transcription-app",
  "version": "1.1.0",
  "description": "语音转录服务桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "voice",
    "transcription",
    "speech",
    "recognition"
  ],
  "author": "AST Module Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.xingjuai.talkingcat",
    "productName": "提猫直播助手",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "python-transcriber/dist/transcriber_service${/*}",
        "to": "python-transcriber",
        "filter": ["**/*"]
      },
      {
        "from": "python-transcriber/models",
        "to": "python-transcriber/models",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "sign": null
    },
    "portable": {
      "artifactName": "TalkingCat-Portable-${version}-${arch}.exe"
    },
    "files": [
      "**/*",
      "!python-transcriber/venv/**",
      "!python-transcriber/build/**",
      "!python-transcriber/__pycache__/**",
      "!python-transcriber/*.spec"
    ]
  }
}
