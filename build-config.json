{
  "appId": "com.xingjuai.talkingcat",
  "productName": "提猫直播助手",
  "artifactName": "TalkingCat-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "dist",
    "buildResources": "assets"
  },
  "files": [
    "electron/main.js",
    "electron/preload.js",
    "electron/renderer/dist/**/*",
    "electron/package.json",
    "package.json",
    "!electron/renderer/src/**/*",
    "!electron/renderer/node_modules/**/*",
    "!electron/renderer/package.json",
    "!electron/renderer/package-lock.json",
    "!electron/renderer/.env*",
    "!electron/node_modules/**/*",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!**/*.pyo",
    "!**/*.log",
    "!**/.git/**",
    "!**/logs/**",
    "!**/test/**",
    "!**/tests/**",
    "!**/.vscode/**",
    "!**/.idea/**"
  ],
  "extraResources": [],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "electron/renderer/src/assets/icon.ico",
    "artifactName": "TalkingCat-Portable-${version}-${arch}.exe",
    "requestedExecutionLevel": "asInvoker"
  },
  "portable": {
    "artifactName": "TalkingCat-Portable-${version}-${arch}.exe"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "artifactName": "TalkingCat-Setup-${version}-${arch}.exe",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "提猫直播助手",
    "include": null,
    "perMachine": false,
    "allowElevation": true
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "electron/renderer/src/assets/icon.icns",
    "artifactName": "TalkingCat-${version}-${arch}.dmg",
    "category": "public.app-category.productivity"
  },
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      }
    ],
    "icon": "electron/renderer/src/assets/icon.png",
    "artifactName": "TalkingCat-${version}-${arch}.${ext}",
    "category": "Office"
  },
  "publish": {
    "provider": "generic",
    "url": "https://releases.example.com/"
  },
  "compression": "maximum",
  "removePackageScripts": true,
  "buildDependenciesFromSource": false,
  "nodeGypRebuild": false,
  "npmRebuild": false
}
